{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/event-payloads/approval_granted.schema.json",
  "title": "approval.granted",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "approval_id",
    "action_id",
    "action_hash",
    "decided_by",
    "lease_epoch"
  ],
  "properties": {
    "approval_id": {
      "type": "string"
    },
    "action_id": {
      "type": "string"
    },
    "action_hash": {
      "type": "string"
    },
    "decided_by": {
      "type": "string"
    },
    "lease_epoch": {
      "type": "integer",
      "minimum": 0
    },
    "approved_argument_digest": {
      "type": [
        "string",
        "null"
      ]
    },
    "capability_token_ref": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
