    "action_id": {
      "type": "string"
    },
    "action_hash": {
      "type": "string"
    },
    "expired_at": {
      "type": "string",
      "format": "date-time"
    },
    "lease_epoch": {
      "type": "integer",
      "minimum": 0
    }
  }
}