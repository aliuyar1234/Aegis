{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/event-payloads/approval_requested.schema.json",
  "title": "approval.requested",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "approval_id",
    "action_id",
    "action_hash",
    "expires_at",
    "risk_class",
    "lease_epoch"
  ],
  "properties": {
    "approval_id": {
      "type": "string"
    },
    "action_id": {
      "type": "string"
    },
    "action_hash": {
      "type": "string"
    },
    "risk_class": {
      "type": "string"
    },
    "dangerous_action_class": {
      "type": [
        "string",
        "null"
      ]
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "lease_epoch": {
      "type": "integer",
      "minimum": 0
    },
    "evidence_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}