{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/event-payloads/action_progressed.schema.json",
  "title": "action.progressed",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action_id",
    "execution_id",
    "progress_kind",
    "progress_seq",
    "observed_at"
  ],
  "properties": {
    "action_id": {
      "type": "string"
    },
    "execution_id": {
      "type": "string"
    },
    "progress_kind": {
      "type": "string"
    },
    "progress_seq": {
      "type": "integer",
      "minimum": 0
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "worker_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "progress": {
      "type": "object"
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
