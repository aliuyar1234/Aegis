{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/recovery-objective.schema.json",
  "title": "RecoveryObjectives",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "profiles"],
  "properties": {
    "id": { "type": "string", "const": "recovery-objectives" },
    "version": { "type": "integer", "minimum": 1 },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "rto_target_minutes", "rpo_target_minutes", "evidence_requirements"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "rto_target_minutes": { "type": "integer", "minimum": 1 },
          "rpo_target_minutes": { "type": "integer", "minimum": 0 },
          "evidence_requirements": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
