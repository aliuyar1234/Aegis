{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/rollout-wave-report.schema.json",
  "title": "RolloutWaveReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "waves", "verdict"],
  "properties": {
    "id": { "type": "string", "const": "phase20-rollout-wave-report" },
    "waves": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "wave_id",
          "promotion_count",
          "evidence_count",
          "notice_count",
          "verdict"
        ],
        "properties": {
          "wave_id": { "type": "string" },
          "promotion_count": { "type": "integer", "minimum": 1 },
          "evidence_count": { "type": "integer", "minimum": 1 },
          "notice_count": { "type": "integer", "minimum": 1 },
          "verdict": { "type": "string", "enum": ["pass", "fail"] }
        }
      }
    },
    "verdict": { "type": "string", "enum": ["pass", "fail"] }
  }
}
