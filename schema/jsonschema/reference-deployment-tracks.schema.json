{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/reference-deployment-tracks.schema.json",
  "title": "ReferenceDeploymentTracks",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "program_id",
    "version",
    "tracks"
  ],
  "properties": {
    "program_id": {
      "type": "string",
      "const": "reference-deployment-tracks"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "display_name",
          "deployment_flavor_id",
          "topology_profile_id",
          "regional_topology_profile_id",
          "slo_profile_id",
          "public_track_id",
          "required_evidence",
          "runbook_refs"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "deployment_flavor_id": {
            "type": "string",
            "pattern": "^[a-z0-9_][a-z0-9_.-]*$"
          },
          "topology_profile_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          },
          "regional_topology_profile_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          },
          "slo_profile_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"
          },
          "public_track_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          },
          "required_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "runbook_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
