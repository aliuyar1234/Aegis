{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/simulation-scenario-manifest.schema.json",
  "title": "SimulationScenarioManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "scenarios"
  ],
  "properties": {
    "id": {
      "type": "string",
      "const": "simulation-scenarios"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "scenarios": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "scenario_ref",
          "covers_faults",
          "expected_terminal_state",
          "tags"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          },
          "scenario_ref": {
            "type": "string",
            "minLength": 1
          },
          "covers_faults": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "worker_crash",
                "node_loss",
                "approval_timeout",
                "duplicate_callback",
                "browser_instability"
              ]
            }
          },
          "expected_terminal_state": {
            "type": "string",
            "minLength": 1
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
