{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/adoption-evidence-bundle.schema.json",
  "title": "AdoptionEvidenceBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "phase",
    "reports",
    "evidence_groups",
    "verdict"
  ],
  "properties": {
    "id": {
      "type": "string",
      "const": "phase19-adoption-evidence-bundle"
    },
    "phase": {
      "type": "string",
      "const": "PHASE-19"
    },
    "reports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "verdict"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^phase19-.+-report$"
          },
          "verdict": {
            "type": "string",
            "enum": [
              "pass",
              "fail"
            ]
          }
        }
      }
    },
    "evidence_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "ref_count"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "ref_count": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    }
  }
}
