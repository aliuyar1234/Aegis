{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/launch-readiness-evidence-manifest.schema.json",
  "title": "LaunchReadinessEvidenceManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "required_scripts", "required_gates", "required_docs"],
  "properties": {
    "id": {"type": "string"},
    "version": {"type": "integer"},
    "required_scripts": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "required_gates": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "required_docs": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    }
  }
}
