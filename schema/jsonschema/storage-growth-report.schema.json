{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/storage-growth-report.schema.json",
  "title": "StorageGrowthReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "scenario_results", "verdict"],
  "properties": {
    "id": { "type": "string", "const": "phase16-storage-growth-report" },
    "scenario_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scenario_id", "component", "budget_profile", "verdict"],
        "properties": {
          "scenario_id": { "type": "string" },
          "component": { "type": "string" },
          "budget_profile": { "type": "string" },
          "verdict": { "type": "string", "enum": ["pass", "fail"] }
        }
      }
    },
    "verdict": { "type": "string", "enum": ["pass", "fail"] }
  }
}
