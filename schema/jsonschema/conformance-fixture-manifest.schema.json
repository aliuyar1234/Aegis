{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/conformance-fixture-manifest.schema.json",
  "title": "ConformanceFixtureManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "fixtures"
  ],
  "properties": {
    "id": {
      "type": "string",
      "const": "runtime-contract-conformance"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "fixtures": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "subject_name",
          "message_name",
          "worker_kind",
          "lifecycle_stage",
          "required_fields"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          },
          "subject_name": {
            "type": "string",
            "minLength": 1
          },
          "message_name": {
            "type": "string",
            "minLength": 1
          },
          "worker_kind": {
            "type": "string",
            "enum": [
              "browser",
              "planner",
              "tool",
              "all"
            ]
          },
          "lifecycle_stage": {
            "type": "string",
            "enum": [
              "registry",
              "dispatch",
              "cancel",
              "accepted",
              "progress",
              "heartbeat",
              "completed",
              "failed",
              "cancelled"
            ]
          },
          "required_fields": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
