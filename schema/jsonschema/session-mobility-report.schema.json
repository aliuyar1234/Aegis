{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/session-mobility-report.schema.json",
  "title": "SessionMobilityReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "scenario_results", "verdict"],
  "properties": {
    "id": { "type": "string", "const": "phase17-session-mobility-report" },
    "scenario_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scenario_id", "expected_authoritative_region", "continuity_count", "verdict"],
        "properties": {
          "scenario_id": { "type": "string" },
          "expected_authoritative_region": { "type": "string" },
          "continuity_count": { "type": "integer", "minimum": 1 },
          "verdict": { "type": "string", "enum": ["pass", "fail"] }
        }
      }
    },
    "verdict": { "type": "string", "enum": ["pass", "fail"] }
  }
}
