{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/policy-bundle-report.schema.json",
  "title": "PolicyBundleReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "bundles",
    "verdict"
  ],
  "properties": {
    "id": {
      "type": "string",
      "const": "phase18-policy-bundle-report"
    },
    "bundles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "bundle_id",
          "explicit_input_count",
          "approval_role_count",
          "explanation_field_count",
          "dual_control_required",
          "verdict"
        ],
        "properties": {
          "bundle_id": {
            "type": "string"
          },
          "explicit_input_count": {
            "type": "integer",
            "minimum": 1
          },
          "approval_role_count": {
            "type": "integer",
            "minimum": 1
          },
          "explanation_field_count": {
            "type": "integer",
            "minimum": 1
          },
          "dual_control_required": {
            "type": "boolean"
          },
          "verdict": {
            "type": "string",
            "enum": [
              "pass",
              "fail"
            ]
          }
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    }
  }
}
