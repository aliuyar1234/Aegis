{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/fault-injection-matrix.schema.json",
  "title": "FaultInjectionMatrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "faults"
  ],
  "properties": {
    "id": {
      "type": "string",
      "const": "fault-injection-matrix"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "faults": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "class",
          "deterministic",
          "target_types",
          "expected_runtime_response"
        ],
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "worker_crash",
              "node_loss",
              "approval_timeout",
              "duplicate_callback",
              "browser_instability"
            ]
          },
          "class": {
            "type": "string"
          },
          "deterministic": {
            "type": "boolean"
          },
          "target_types": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "expected_runtime_response": {
            "type": "string"
          }
        }
      }
    }
  }
}
