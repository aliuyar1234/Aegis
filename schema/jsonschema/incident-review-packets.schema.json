{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/incident-review-packets.schema.json",
  "title": "IncidentReviewPackets",
  "type": "object",
  "additionalProperties": false,
  "required": ["program_id", "version", "packets"],
  "properties": {
    "program_id": { "type": "string", "const": "incident-review-packets" },
    "version": { "type": "integer", "const": 1 },
    "packets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "incident_class",
          "source_exercise",
          "accreditation_track",
          "required_evidence",
          "runbook_refs",
          "follow_up_refs"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "incident_class": { "type": "string", "pattern": "^[a-z_][a-z0-9_]*$" },
          "source_exercise": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "accreditation_track": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "required_evidence": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "runbook_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "follow_up_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
