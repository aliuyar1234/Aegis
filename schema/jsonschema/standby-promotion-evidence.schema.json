{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/standby-promotion-evidence.schema.json",
  "title": "StandbyPromotionEvidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "promotions"],
  "properties": {
    "id": { "type": "string", "const": "standby-promotion-evidence" },
    "version": { "type": "integer", "minimum": 1 },
    "promotions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "topology_profile", "recovery_drill_id", "fencing_confirmed", "restore_evidence_confirmed", "single_owner_verified"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "topology_profile": { "type": "string" },
          "recovery_drill_id": { "type": "string" },
          "fencing_confirmed": { "type": "boolean" },
          "restore_evidence_confirmed": { "type": "boolean" },
          "single_owner_verified": { "type": "boolean" }
        }
      }
    }
  }
}
