{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/regional-evacuation-manifest.schema.json",
  "title": "RegionalEvacuationManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "drills"],
  "properties": {
    "id": { "type": "string", "const": "regional-evacuation-fixtures" },
    "version": { "type": "integer", "minimum": 1 },
    "drills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "topology_profile_ref", "trigger", "source_region", "target_region", "expected_steps"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "topology_profile_ref": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "trigger": { "type": "string", "minLength": 1 },
          "source_region": { "type": "string", "minLength": 1 },
          "target_region": { "type": "string", "minLength": 1 },
          "expected_steps": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
