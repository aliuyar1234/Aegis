{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/simulation-result.schema.json",
  "title": "SimulationResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "scenario_id",
    "seed",
    "emitted_events",
    "faults_applied",
    "terminal_state",
    "invariants",
    "result_signature"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "scenario_id": {
      "type": "string"
    },
    "seed": {
      "type": "integer",
      "minimum": 1
    },
    "emitted_events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "seq_no",
          "step_id",
          "event_type"
        ],
        "properties": {
          "seq_no": {
            "type": "integer",
            "minimum": 1
          },
          "step_id": {
            "type": "string"
          },
          "event_type": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "faults_applied": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "terminal_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_state",
        "recovery_status",
        "uncertainty_status",
        "quarantine_status",
        "replay_equivalent"
      ],
      "properties": {
        "session_state": {
          "type": "string"
        },
        "recovery_status": {
          "type": "string"
        },
        "uncertainty_status": {
          "type": "string"
        },
        "quarantine_status": {
          "type": "string"
        },
        "replay_equivalent": {
          "type": "boolean"
        }
      }
    },
    "invariants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "result_signature": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
