{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/regional-evacuation-report.schema.json",
  "title": "RegionalEvacuationReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "drill_results", "verdict"],
  "properties": {
    "id": { "type": "string", "const": "phase17-regional-evacuation-report" },
    "drill_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["drill_id", "step_count", "source_region", "target_region", "verdict"],
        "properties": {
          "drill_id": { "type": "string" },
          "step_count": { "type": "integer", "minimum": 1 },
          "source_region": { "type": "string" },
          "target_region": { "type": "string" },
          "verdict": { "type": "string", "enum": ["pass", "fail"] }
        }
      }
    },
    "verdict": { "type": "string", "enum": ["pass", "fail"] }
  }
}
