{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/regional-placement-policies.schema.json",
  "title": "RegionalPlacementPolicies",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "policies", "decision_fixtures"],
  "properties": {
    "id": { "type": "string", "const": "regional-placement-policies" },
    "version": { "type": "integer", "minimum": 1 },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "topology_profile_ref",
          "prefer_primary_region",
          "allow_standby_on_failover",
          "required_fault_domain_roles",
          "preserve_single_owner"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "topology_profile_ref": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "prefer_primary_region": { "type": "boolean" },
          "allow_standby_on_failover": { "type": "boolean" },
          "required_fault_domain_roles": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "preserve_single_owner": { "type": "boolean" }
        }
      }
    },
    "decision_fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "policy_ref", "tenant_tier", "topology_state", "source_region", "expected_region"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "policy_ref": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "tenant_tier": { "type": "string", "minLength": 1 },
          "topology_state": { "type": "string", "minLength": 1 },
          "source_region": { "type": "string", "minLength": 1 },
          "expected_region": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
