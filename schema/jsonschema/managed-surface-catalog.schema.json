{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/managed-surface-catalog.schema.json",
  "title": "ManagedSurfaceCatalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "managed_surfaces"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]*$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "managed_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "category",
          "included_flavors",
          "capabilities",
          "depends_on_oss_core",
          "evidence_refs"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          },
          "category": {
            "type": "string",
            "enum": [
              "control_plane_service",
              "execution_isolation",
              "operational_feature",
              "commercial_surface",
              "deployment_service"
            ]
          },
          "included_flavors": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "shared_cloud",
                "isolated_execution",
                "dedicated_deployment"
              ]
            }
          },
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "depends_on_oss_core": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
