{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/media-sidecar-catalog.schema.json",
  "title": "MediaSidecarCatalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "contracts"
  ],
  "$defs": {
    "ownershipBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_owner",
        "writes_canonical_state_directly",
        "owns_session_lease",
        "emits_runtime_events_directly",
        "replay_source"
      ],
      "properties": {
        "session_owner": {
          "const": "elixir_control_plane"
        },
        "writes_canonical_state_directly": {
          "const": false
        },
        "owns_session_lease": {
          "const": false
        },
        "emits_runtime_events_directly": {
          "const": false
        },
        "replay_source": {
          "type": "string",
          "enum": [
            "recorded_artifacts",
            "transcripts_and_artifacts"
          ]
        }
      }
    },
    "commandBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receives",
        "emits",
        "policy_enforced_by"
      ],
      "properties": {
        "receives": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "action_dispatch",
              "action_cancel"
            ]
          }
        },
        "emits": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "action_accepted",
              "action_progress",
              "action_completed",
              "action_failed",
              "action_cancelled",
              "artifact_registered"
            ]
          }
        },
        "policy_enforced_by": {
          "const": "aegis_policy"
        }
      }
    },
    "artifactBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_kinds",
        "signed_upload_required",
        "retention_classes"
      ],
      "properties": {
        "artifact_kinds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "signed_upload_required": {
          "const": true
        },
        "retention_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "capacityBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pool_class",
        "max_streams_per_sidecar",
        "degradation_signal"
      ],
      "properties": {
        "pool_class": {
          "type": "string",
          "enum": [
            "shared_media_pool",
            "tenant_isolated_media_pool",
            "dedicated_media_pool"
          ]
        },
        "max_streams_per_sidecar": {
          "type": "integer",
          "minimum": 1
        },
        "degradation_signal": {
          "type": "string",
          "enum": [
            "health.degraded",
            "operator_handoff_required",
            "recording_backpressure"
          ]
        }
      }
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sidecar_id",
        "kind",
        "runtime_language",
        "ownership_boundary",
        "command_boundary",
        "artifact_boundary",
        "capacity_boundary"
      ],
      "properties": {
        "sidecar_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]*$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "media_gateway",
            "recorder",
            "protocol_bridge"
          ]
        },
        "runtime_language": {
          "const": "rust"
        },
        "ownership_boundary": {
          "$ref": "#/$defs/ownershipBoundary"
        },
        "command_boundary": {
          "$ref": "#/$defs/commandBoundary"
        },
        "artifact_boundary": {
          "$ref": "#/$defs/artifactBoundary"
        },
        "capacity_boundary": {
          "$ref": "#/$defs/capacityBoundary"
        }
      }
    }
  },
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "contracts": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/contract"
      }
    }
  }
}
