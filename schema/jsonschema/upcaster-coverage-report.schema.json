{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/upcaster-coverage-report.schema.json",
  "title": "UpcasterCoverageReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "fixture_results", "verdict"],
  "properties": {
    "id": { "type": "string", "const": "phase15-upcaster-coverage-report" },
    "fixture_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fixture_id", "resolved_target_version", "verdict"],
        "properties": {
          "fixture_id": { "type": "string" },
          "resolved_target_version": { "type": ["string", "null"] },
          "verdict": { "type": "string", "enum": ["pass", "fail"] }
        }
      }
    },
    "verdict": { "type": "string", "enum": ["pass", "fail"] }
  }
}
