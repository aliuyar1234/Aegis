{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/regional-evidence-manifest.schema.json",
  "title": "RegionalEvidenceManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "bundle_id", "required_reports", "evidence_groups"],
  "properties": {
    "id": { "type": "string", "const": "regional-evidence-manifest" },
    "version": { "type": "integer", "minimum": 1 },
    "bundle_id": { "type": "string", "const": "phase17-regional-evidence-bundle" },
    "required_reports": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^phase17-.+-report$" }
    },
    "evidence_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "refs"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
