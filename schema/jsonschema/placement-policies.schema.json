{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/placement-policies.schema.json",
  "title": "PlacementPolicies",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "pool_taxonomy", "rules", "decision_fixtures"],
  "properties": {
    "id": { "type": "string", "const": "placement-policies" },
    "version": { "type": "integer", "minimum": 1 },
    "pool_taxonomy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "pool_kind",
          "fault_domain",
          "supported_tiers",
          "capabilities",
          "isolation_mode",
          "priority",
          "active"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "pool_kind": { "type": "string", "minLength": 1 },
          "fault_domain": { "type": "string", "minLength": 1 },
          "supported_tiers": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" }
          },
          "isolation_mode": { "type": "string", "minLength": 1 },
          "priority": { "type": "integer", "minimum": 1 },
          "active": { "type": "boolean" }
        }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "decision_fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "tenant_tier",
          "required_capability",
          "preferred_fault_domain",
          "expected_pool"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "tenant_tier": { "type": "string", "minLength": 1 },
          "required_capability": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "preferred_fault_domain": { "type": "string", "minLength": 1 },
          "expected_pool": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" }
        }
      }
    }
  }
}
