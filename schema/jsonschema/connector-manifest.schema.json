{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/connector-manifest.schema.json",
  "title": "ExtensionManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "display_name",
    "version",
    "kind",
    "sdk",
    "runtime_contract_version",
    "extension_api_version",
    "lifecycle",
    "capability_boundary",
    "compatibility"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*(\\.[a-z0-9_-]+)*$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "$ref": "#/$defs/versionString"
    },
    "kind": {
      "type": "string",
      "enum": [
        "tool_connector",
        "artifact_processor",
        "mcp_adapter"
      ]
    },
    "sdk": {
      "$ref": "#/$defs/sdk"
    },
    "runtime_contract_version": {
      "type": "string",
      "minLength": 1
    },
    "extension_api_version": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle": {
      "$ref": "#/$defs/lifecycle"
    },
    "capability_boundary": {
      "$ref": "#/$defs/capabilityBoundary"
    },
    "compatibility": {
      "$ref": "#/$defs/compatibility"
    },
    "tool_connector": {
      "$ref": "#/$defs/toolConnectorInterface"
    },
    "artifact_processor": {
      "$ref": "#/$defs/artifactProcessorInterface"
    },
    "mcp_adapter": {
      "$ref": "#/$defs/mcpAdapterInterface"
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "tool_connector"
          }
        }
      },
      "then": {
        "required": [
          "tool_connector"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "artifact_processor"
          }
        }
      },
      "then": {
        "required": [
          "artifact_processor"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "mcp_adapter"
          }
        }
      },
      "then": {
        "required": [
          "mcp_adapter"
        ]
      }
    }
  ],
  "$defs": {
    "versionString": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]*$"
    },
    "versionRange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min",
        "max"
      ],
      "properties": {
        "min": {
          "$ref": "#/$defs/versionString"
        },
        "max": {
          "$ref": "#/$defs/versionString"
        }
      }
    },
    "sdk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language",
        "package",
        "entry_module"
      ],
      "properties": {
        "language": {
          "type": "string",
          "enum": [
            "elixir",
            "python",
            "rust"
          ]
        },
        "package": {
          "type": "string",
          "minLength": 1
        },
        "entry_module": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "lifecycleHook": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handler",
        "timeout_class",
        "idempotent"
      ],
      "properties": {
        "handler": {
          "type": "string",
          "minLength": 1
        },
        "timeout_class": {
          "type": "string",
          "enum": [
            "short",
            "medium",
            "long",
            "manual_only"
          ]
        },
        "idempotent": {
          "type": "boolean"
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "install",
        "start",
        "health_check",
        "run",
        "shutdown"
      ],
      "properties": {
        "install": {
          "$ref": "#/$defs/lifecycleHook"
        },
        "start": {
          "$ref": "#/$defs/lifecycleHook"
        },
        "health_check": {
          "$ref": "#/$defs/lifecycleHook"
        },
        "run": {
          "$ref": "#/$defs/lifecycleHook"
        },
        "shutdown": {
          "$ref": "#/$defs/lifecycleHook"
        }
      }
    },
    "networkBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "egress_allowlist"
          ]
        },
        "allowlist": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "egress_allowlist"
              }
            }
          },
          "then": {
            "required": [
              "allowlist"
            ],
            "properties": {
              "allowlist": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "artifactAccess": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inputs",
        "outputs"
      ],
      "properties": {
        "inputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "capabilityBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_scopes",
        "allowed_tools",
        "dangerous_action_classes",
        "secrets",
        "network",
        "artifact_access"
      ],
      "properties": {
        "required_scopes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowed_tools": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          }
        },
        "dangerous_action_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          }
        },
        "secrets": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_]+$"
          }
        },
        "network": {
          "$ref": "#/$defs/networkBoundary"
        },
        "artifact_access": {
          "$ref": "#/$defs/artifactAccess"
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aegis_runtime",
        "extension_api",
        "tool_registry",
        "supported_tiers"
      ],
      "properties": {
        "aegis_runtime": {
          "$ref": "#/$defs/versionRange"
        },
        "extension_api": {
          "$ref": "#/$defs/versionRange"
        },
        "tool_registry": {
          "$ref": "#/$defs/versionRange"
        },
        "supported_tiers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "tier_a",
              "tier_b",
              "tier_c"
            ]
          },
          "minItems": 1
        }
      }
    },
    "toolConnectorInterface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tools"
      ],
      "properties": {
        "tools": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "tool_id",
              "input_schema_ref",
              "output_schema_ref",
              "executor_kind",
              "artifact_expectations"
            ],
            "properties": {
              "tool_id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9_.-]*$"
              },
              "input_schema_ref": {
                "type": "string",
                "minLength": 1
              },
              "output_schema_ref": {
                "type": "string",
                "minLength": 1
              },
              "executor_kind": {
                "type": "string",
                "enum": [
                  "python",
                  "rust"
                ]
              },
              "mutating": {
                "type": "boolean"
              },
              "artifact_expectations": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "artifactProcessorInterface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accepted_artifact_kinds",
        "emitted_artifact_kinds",
        "processing_mode",
        "max_input_bytes"
      ],
      "properties": {
        "accepted_artifact_kinds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "emitted_artifact_kinds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "processing_mode": {
          "type": "string",
          "enum": [
            "batch",
            "stream"
          ]
        },
        "max_input_bytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "mcpSessionBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requires_session_owner_dispatch",
        "maps_to_action_requests_only",
        "returns_worker_events_only"
      ],
      "properties": {
        "requires_session_owner_dispatch": {
          "const": true
        },
        "maps_to_action_requests_only": {
          "const": true
        },
        "returns_worker_events_only": {
          "const": true
        }
      }
    },
    "mcpProtocolBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mcp_is_internal_runtime_protocol",
        "writes_canonical_state_directly",
        "emits_runtime_events_directly",
        "bypasses_policy",
        "bypasses_outbox"
      ],
      "properties": {
        "mcp_is_internal_runtime_protocol": {
          "const": false
        },
        "writes_canonical_state_directly": {
          "const": false
        },
        "emits_runtime_events_directly": {
          "const": false
        },
        "bypasses_policy": {
          "const": false
        },
        "bypasses_outbox": {
          "const": false
        }
      }
    },
    "mcpToolTranslation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "published_tool_ids"
      ],
      "properties": {
        "published_tool_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          }
        },
        "tool_name_prefix": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]*$"
        },
        "allow_prompt_passthrough": {
          "type": "boolean"
        },
        "allow_resource_passthrough": {
          "type": "boolean"
        }
      }
    },
    "mcpAdapterInterface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "server_transport",
        "server_ref",
        "protocol_role",
        "session_binding",
        "tool_translation",
        "protocol_boundary"
      ],
      "properties": {
        "server_transport": {
          "type": "string",
          "enum": [
            "stdio",
            "sse",
            "streamable_http"
          ]
        },
        "server_ref": {
          "type": "string",
          "minLength": 1
        },
        "protocol_role": {
          "const": "external_tool_adapter"
        },
        "session_binding": {
          "$ref": "#/$defs/mcpSessionBinding"
        },
        "tool_translation": {
          "$ref": "#/$defs/mcpToolTranslation"
        },
        "protocol_boundary": {
          "$ref": "#/$defs/mcpProtocolBoundary"
        }
      }
    }
  }
}
