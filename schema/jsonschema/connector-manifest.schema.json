{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/connector-manifest.schema.json",
  "title": "ConnectorManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "kind",
    "input_schema_ref",
    "output_schema_ref",
    "runtime_contract_version"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "tool_connector",
        "artifact_processor",
        "mcp_adapter"
      ]
    },
    "input_schema_ref": {
      "type": "string"
    },
    "output_schema_ref": {
      "type": "string"
    },
    "runtime_contract_version": {
      "type": "string"
    },
    "compatibility": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
