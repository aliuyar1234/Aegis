{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/operator-accreditation-report.schema.json",
  "title": "OperatorAccreditationReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "tracks", "verdict"],
  "properties": {
    "id": { "type": "string", "const": "phase20-operator-accreditation-report" },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "track_id",
          "exercise_count",
          "evidence_count",
          "deployment_track_count",
          "verdict"
        ],
        "properties": {
          "track_id": { "type": "string" },
          "exercise_count": { "type": "integer", "minimum": 1 },
          "evidence_count": { "type": "integer", "minimum": 1 },
          "deployment_track_count": { "type": "integer", "minimum": 1 },
          "verdict": { "type": "string", "enum": ["pass", "fail"] }
        }
      }
    },
    "verdict": { "type": "string", "enum": ["pass", "fail"] }
  }
}
