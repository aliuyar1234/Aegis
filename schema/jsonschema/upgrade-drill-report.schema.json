{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/upgrade-drill-report.schema.json",
  "title": "UpgradeDrillReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "drill_results", "verdict"],
  "properties": {
    "id": { "type": "string", "const": "phase15-upgrade-drill-report" },
    "drill_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["drill_id", "strategy_ref", "skew_rule_id", "verdict"],
        "properties": {
          "drill_id": { "type": "string" },
          "strategy_ref": { "type": "string" },
          "skew_rule_id": { "type": "string" },
          "verdict": { "type": "string", "enum": ["pass", "fail"] }
        }
      }
    },
    "verdict": { "type": "string", "enum": ["pass", "fail"] }
  }
}
