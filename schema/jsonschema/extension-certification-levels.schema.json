{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/extension-certification-levels.schema.json",
  "title": "ExtensionCertificationLevels",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "program_id",
    "version",
    "signing_profile",
    "levels",
    "review_windows",
    "candidates"
  ],
  "properties": {
    "program_id": {
      "type": "string",
      "const": "aegis-extension-certification"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "signing_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "digest_algorithm",
        "signer_role"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]*$"
        },
        "digest_algorithm": {
          "type": "string",
          "const": "sha256"
        },
        "signer_role": {
          "type": "string",
          "pattern": "^[a-z_][a-z0-9_]*$"
        }
      }
    },
    "levels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "display_name",
          "requirements"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "requirements": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "schema_valid",
              "compatibility_bounded",
              "sandbox_profile_required",
              "certification_report_required",
              "public_listing_allowed",
              "required_evidence_groups"
            ],
            "properties": {
              "schema_valid": {
                "type": "boolean"
              },
              "compatibility_bounded": {
                "type": "boolean"
              },
              "sandbox_profile_required": {
                "type": "boolean"
              },
              "certification_report_required": {
                "type": "boolean"
              },
              "public_listing_allowed": {
                "type": "boolean"
              },
              "required_evidence_groups": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_-]*$"
                }
              }
            }
          }
        }
      }
    },
    "review_windows": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "revocation_sla_hours",
        "required_recertification_days"
      ],
      "properties": {
        "revocation_sla_hours": {
          "type": "integer",
          "minimum": 1
        },
        "required_recertification_days": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "pack_ref",
          "target_level",
          "required_profiles",
          "policy_bundle",
          "public_track"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          },
          "pack_ref": {
            "type": "string",
            "minLength": 1
          },
          "target_level": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          },
          "required_profiles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9_.-]*$"
            }
          },
          "policy_bundle": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          },
          "public_track": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          }
        }
      }
    }
  }
}
