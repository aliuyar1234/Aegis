{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/fresh-clone-onboarding.schema.json",
  "title": "FreshCloneOnboarding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "canonical_docs",
    "read_order",
    "official_commands",
    "agents_required_refs",
    "readme_required_snippets",
    "required_scripts"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "canonical_docs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "read_order": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "official_commands": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "agents_required_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "readme_required_snippets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "required_scripts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}
