{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/phase-gate.schema.json",
  "title": "PhaseGate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "phase",
    "name",
    "objective",
    "fixtures",
    "tests",
    "acceptance",
    "steps",
    "proves"
  ],
  "$defs": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "expected",
        "evidence"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "expected": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    }
  },
  "properties": {
    "id": {
      "type": "string"
    },
    "phase": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "fixtures": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/step"
      },
      "minItems": 1
    },
    "proves": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}