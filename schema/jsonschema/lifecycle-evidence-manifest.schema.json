{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/lifecycle-evidence-manifest.schema.json",
  "title": "LifecycleEvidenceManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["bundle_id", "phase", "evidence_groups"],
  "properties": {
    "bundle_id": { "type": "string", "const": "phase20-lifecycle-evidence-bundle" },
    "phase": { "type": "string", "const": "PHASE-20" },
    "evidence_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "refs"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
          "refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
