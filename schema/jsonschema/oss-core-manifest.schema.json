{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/oss-core-manifest.schema.json",
  "title": "OssCoreManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "runtime_release",
    "support_boundary",
    "oss_core",
    "bounded_exclusions"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]*$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "runtime_release": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]*$"
    },
    "support_boundary": {
      "type": "string",
      "enum": [
        "community_supported_self_managed"
      ]
    },
    "oss_core": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_plane_apps",
        "execution_plane_packages",
        "contracts",
        "operator_surfaces",
        "self_hosted_backplane",
        "distribution_artifacts"
      ],
      "properties": {
        "control_plane_apps": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "execution_plane_packages": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "contracts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "operator_surfaces": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "self_hosted_backplane": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "postgresql",
              "nats_jetstream",
              "s3_compatible_object_store",
              "otel_collector_optional"
            ]
          }
        },
        "distribution_artifacts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "bounded_exclusions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "managed_control_plane_services",
        "operational_features",
        "deployment_flavors_not_included"
      ],
      "properties": {
        "managed_control_plane_services": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "operational_features": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "deployment_flavors_not_included": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "shared_cloud",
              "isolated_execution",
              "dedicated_deployment"
            ]
          }
        }
      }
    }
  }
}
