{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/release-evidence-bundle.schema.json",
  "title": "ReleaseEvidenceBundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "candidate", "reports", "required_gates", "verdict"],
  "properties": {
    "id": { "type": "string", "const": "phase15-release-evidence-bundle" },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["release_id", "runtime_release"],
      "properties": {
        "release_id": { "type": "string" },
        "runtime_release": { "type": "string" }
      }
    },
    "reports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "verdict"],
        "properties": {
          "id": { "type": "string" },
          "verdict": { "type": "string", "enum": ["pass", "fail"] }
        }
      }
    },
    "required_gates": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "verdict": { "type": "string", "enum": ["pass", "fail"] }
  }
}
