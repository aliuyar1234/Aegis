{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/incident-review-packet-report.schema.json",
  "title": "IncidentReviewPacketReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "packets", "verdict"],
  "properties": {
    "id": { "type": "string", "const": "phase20-incident-review-packet-report" },
    "packets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "packet_id",
          "runbook_count",
          "evidence_count",
          "follow_up_count",
          "verdict"
        ],
        "properties": {
          "packet_id": { "type": "string" },
          "runbook_count": { "type": "integer", "minimum": 1 },
          "evidence_count": { "type": "integer", "minimum": 1 },
          "follow_up_count": { "type": "integer", "minimum": 1 },
          "verdict": { "type": "string", "enum": ["pass", "fail"] }
        }
      }
    },
    "verdict": { "type": "string", "enum": ["pass", "fail"] }
  }
}
