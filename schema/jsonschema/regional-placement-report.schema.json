{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/regional-placement-report.schema.json",
  "title": "RegionalPlacementReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "decisions", "verdict"],
  "properties": {
    "id": { "type": "string", "const": "phase17-regional-placement-report" },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fixture_id", "selected_region", "expected_region", "verdict"],
        "properties": {
          "fixture_id": { "type": "string" },
          "selected_region": { "type": "string" },
          "expected_region": { "type": "string" },
          "verdict": { "type": "string", "enum": ["pass", "fail"] }
        }
      }
    },
    "verdict": { "type": "string", "enum": ["pass", "fail"] }
  }
}
