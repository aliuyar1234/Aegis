{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/capacity-report.schema.json",
  "title": "CapacityReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "profile_results", "verdict"],
  "properties": {
    "id": { "type": "string", "const": "phase16-capacity-report" },
    "profile_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "profile_id",
          "budget_profile",
          "overload_policy_ref",
          "protected_classes",
          "sli_count",
          "verdict"
        ],
        "properties": {
          "profile_id": { "type": "string" },
          "budget_profile": { "type": "string" },
          "overload_policy_ref": { "type": "string" },
          "protected_classes": { "type": "integer", "minimum": 1 },
          "sli_count": { "type": "integer", "minimum": 1 },
          "verdict": { "type": "string", "enum": ["pass", "fail"] }
        }
      }
    },
    "verdict": { "type": "string", "enum": ["pass", "fail"] }
  }
}
