{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/browserworkflowfixture.schema.json",
  "title": "BrowserWorkflowFixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "mutation_class",
    "requires_approval",
    "steps"
  ],
  "$defs": {
    "expectation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contains": {
          "type": "string"
        },
        "equals": {
          "type": "string"
        },
        "artifact_kind": {
          "type": "string"
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "open_context",
            "navigate",
            "extract",
            "click",
            "fill",
            "submit",
            "verify",
            "take_screenshot",
            "take_dom_snapshot",
            "read"
          ]
        },
        "selector": {
          "type": [
            "string",
            "null"
          ]
        },
        "target_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "expectation": {
          "anyOf": [
            {
              "$ref": "#/$defs/expectation"
            },
            {
              "type": "null"
            }
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        },
        "value": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "navigate"
              }
            }
          },
          "then": {
            "required": [
              "target_url"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "click",
                  "submit"
                ]
              }
            }
          },
          "then": {
            "required": [
              "selector"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "fill"
              }
            }
          },
          "then": {
            "required": [
              "selector",
              "value"
            ]
          }
        }
      ]
    }
  },
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "tool_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "risk_class": {
      "type": [
        "string",
        "null"
      ]
    },
    "mutation_class": {
      "type": "string"
    },
    "requires_approval": {
      "type": "boolean"
    },
    "requires_operator_takeover_on_uncertainty": {
      "type": "boolean"
    },
    "expected_policy_decision": {
      "type": [
        "string",
        "null"
      ]
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "expected_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "uncertainty_trigger": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
