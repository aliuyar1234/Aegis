{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/isolation-report.schema.json",
  "title": "IsolationReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "scenario_results", "verdict"],
  "properties": {
    "id": { "type": "string", "const": "phase16-isolation-report" },
    "scenario_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scenario_id", "profile_id", "preserve_classes", "verdict"],
        "properties": {
          "scenario_id": { "type": "string" },
          "profile_id": { "type": "string" },
          "preserve_classes": { "type": "integer", "minimum": 1 },
          "verdict": { "type": "string", "enum": ["pass", "fail"] }
        }
      }
    },
    "verdict": { "type": "string", "enum": ["pass", "fail"] }
  }
}
