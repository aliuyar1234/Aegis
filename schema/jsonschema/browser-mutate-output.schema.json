{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/browser-mutate-output.schema.json",
  "title": "BrowserMutateOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "accepted",
        "completed"
      ]
    },
    "artifact_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "page_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    }
  }
}
