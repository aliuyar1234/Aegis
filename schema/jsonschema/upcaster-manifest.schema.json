{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/upcaster-manifest.schema.json",
  "title": "UpcasterManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "upcasters"],
  "properties": {
    "id": { "type": "string", "const": "upcaster-manifests" },
    "version": { "type": "integer", "minimum": 1 },
    "upcasters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "subject_kind", "subject_id", "from_version", "to_version", "strategy", "handler_ref"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "subject_kind": { "type": "string", "enum": ["checkpoint", "event_payload"] },
          "subject_id": { "type": "string", "minLength": 1 },
          "from_version": { "type": "string", "minLength": 1 },
          "to_version": { "type": "string", "minLength": 1 },
          "strategy": { "type": "string", "minLength": 1 },
          "handler_ref": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
