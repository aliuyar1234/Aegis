{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/transport-topology.schema.json",
  "title": "TransportTopology",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "headers",
    "message_size",
    "streams",
    "subjects",
    "consumers",
    "policies"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "headers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "message_size": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_bytes",
        "oversize_policy"
      ],
      "properties": {
        "max_bytes": {
          "type": "integer",
          "minimum": 1024
        },
        "oversize_policy": {
          "type": "string"
        }
      }
    },
    "streams": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "subjects",
          "retention",
          "storage",
          "replicas",
          "max_age"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "subjects": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "retention": {
            "type": "string"
          },
          "storage": {
            "type": "string"
          },
          "replicas": {
            "type": "integer",
            "minimum": 1
          },
          "max_age": {
            "type": "string"
          }
        }
      }
    },
    "subjects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "subject",
          "direction",
          "message"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "direction": {
            "type": "string",
            "enum": [
              "control->worker",
              "worker->control"
            ]
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "consumers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "stream",
          "filter_subject",
          "ack_policy",
          "ack_wait",
          "max_deliver"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "stream": {
            "type": "string"
          },
          "filter_subject": {
            "type": "string"
          },
          "ack_policy": {
            "type": "string"
          },
          "ack_wait": {
            "type": "string"
          },
          "max_deliver": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "policies": {
      "type": "object"
    }
  }
}