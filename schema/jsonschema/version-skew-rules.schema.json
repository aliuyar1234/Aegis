{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/version-skew-rules.schema.json",
  "title": "VersionSkewRules",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "rules"],
  "properties": {
    "id": { "type": "string", "const": "version-skew-rules" },
    "version": { "type": "integer", "minimum": 1 },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "components", "allowed_skew", "deny_when", "notes"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "components": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "allowed_skew": { "type": "string", "minLength": 1 },
          "deny_when": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "notes": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
