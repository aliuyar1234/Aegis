{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/release-evidence-manifest.schema.json",
  "title": "ReleaseEvidenceManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "candidate", "required_reports", "required_gates"],
  "properties": {
    "id": { "type": "string", "const": "release-evidence-manifest" },
    "version": { "type": "integer", "minimum": 1 },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["release_id", "runtime_release"],
      "properties": {
        "release_id": { "type": "string", "minLength": 1 },
        "runtime_release": { "type": "string", "minLength": 1 }
      }
    },
    "required_reports": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "required_gates": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
