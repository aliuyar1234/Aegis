{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/media-session-extension.schema.json",
  "title": "MediaSessionExtension",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "media_mode",
    "qos_state",
    "capacity_isolation",
    "active_sidecars",
    "recording",
    "handoff",
    "replay_boundary"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "media_mode": {
      "type": "string",
      "enum": [
        "voice_call",
        "live_room",
        "async_review"
      ]
    },
    "qos_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "reason",
        "operator_visibility"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "healthy",
            "degraded",
            "handoff_required",
            "paused_for_backpressure"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "operator_visibility": {
          "const": "explicit"
        }
      }
    },
    "capacity_isolation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pool_class",
        "reservation_required",
        "max_concurrent_sessions"
      ],
      "properties": {
        "pool_class": {
          "type": "string",
          "enum": [
            "shared_media_pool",
            "tenant_isolated_media_pool",
            "dedicated_media_pool"
          ]
        },
        "reservation_required": {
          "type": "boolean"
        },
        "max_concurrent_sessions": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "active_sidecars": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9_.-]*$"
      }
    },
    "recording": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "consent_state",
        "artifact_kind"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "disabled",
            "buffered",
            "active",
            "paused"
          ]
        },
        "consent_state": {
          "type": "string",
          "enum": [
            "not_required",
            "required_pending",
            "granted",
            "revoked"
          ]
        },
        "artifact_kind": {
          "type": "string",
          "enum": [
            "recording_segment",
            "recording_manifest",
            "transcript"
          ]
        }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operator_handoff_required",
        "target_surface",
        "reason"
      ],
      "properties": {
        "operator_handoff_required": {
          "type": "boolean"
        },
        "target_surface": {
          "type": "string",
          "enum": [
            "session-detail",
            "session-fleet",
            "replay"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "replay_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_replay_supported",
        "reconstruct_from"
      ],
      "properties": {
        "packet_replay_supported": {
          "const": false
        },
        "reconstruct_from": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "event_timeline",
              "transcript",
              "recording_manifest",
              "artifact_refs"
            ]
          }
        }
      }
    }
  }
}
