{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/browser-submit-output.schema.json",
  "title": "BrowserSubmitOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "submitted",
        "uncertain",
        "rejected"
      ]
    },
    "artifact_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trace_artifact_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "summary": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}
