{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/upcaster-fixture-manifest.schema.json",
  "title": "UpcasterFixtureManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "fixtures"],
  "properties": {
    "id": { "type": "string", "const": "upcaster-fixtures" },
    "version": { "type": "integer", "minimum": 1 },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "subject_kind", "subject_id", "input_version", "expected_outcome", "expected_target_version"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "subject_kind": { "type": "string", "enum": ["checkpoint", "event_payload"] },
          "subject_id": { "type": "string" },
          "input_version": { "type": "string" },
          "expected_outcome": { "type": "string", "enum": ["upcast_to_current", "incompatible_quarantine"] },
          "expected_target_version": { "type": ["string", "null"] }
        }
      }
    }
  }
}
