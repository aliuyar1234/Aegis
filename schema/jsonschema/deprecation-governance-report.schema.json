{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.runtime/schema/deprecation-governance-report.schema.json",
  "title": "DeprecationGovernanceReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "policies", "verdict"],
  "properties": {
    "id": { "type": "string", "const": "phase20-deprecation-governance-report" },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "policy_id",
          "asset_count",
          "successor_count",
          "notice_window_days",
          "verdict"
        ],
        "properties": {
          "policy_id": { "type": "string" },
          "asset_count": { "type": "integer", "minimum": 1 },
          "successor_count": { "type": "integer", "minimum": 1 },
          "notice_window_days": { "type": "integer", "minimum": 1 },
          "verdict": { "type": "string", "enum": ["pass", "fail"] }
        }
      }
    },
    "verdict": { "type": "string", "enum": ["pass", "fail"] }
  }
}
